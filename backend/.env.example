APP_NAME=Universe Visualizer API
APP_ENV=development
API_PREFIX=/api
LOG_LEVEL=INFO
FRONTEND_ORIGIN=http://localhost:5173

UNIVERSE_DEMO_MODE=false
ENABLE_LIVE_PROVIDERS=true
REQUEST_TIMEOUT_SECONDS=10

ORBIT_CACHE_TTL_SECONDS=300
NEO_CACHE_TTL_SECONDS=1800
SOLAR_CACHE_TTL_SECONDS=21600
DEEP_SPACE_CACHE_TTL_SECONDS=86400
CONTENT_CACHE_TTL_SECONDS=21600
ACTIVE_SATELLITE_LIMIT=60
ORBIT_PREDICTION_STEPS=18
ORBIT_PREDICTION_STEP_MINUTES=10

//need to put your own here, you can get one for free at https://api.nasa.gov
NASA_API_KEY=DEMO_KEY
NASA_API_BASE=https://api.nasa.gov
CELESTRAK_BASE=https://celestrak.org/NORAD/elements
JPL_HORIZONS_BASE=https://ssd.jpl.nasa.gov/api/horizons.api

REFRESH_ORBIT_SECONDS=300
REFRESH_NEO_SECONDS=1800
REFRESH_SOLAR_SECONDS=21600
REFRESH_DEEP_SPACE_SECONDS=86400
REFRESH_CONTENT_SECONDS=21600
